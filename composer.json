{
  "name": "roxcms/game",
  "description": "RoxCMS Servidor MuOnline",
  "type": "project",
  "license": "proprietary",
  "keywords": [
    "thor",
    "mu",
    "mmorpg",
    "muonline",
    "mu",
    "game",
    "mundo aberto"
  ],
  "autoload": {
    "psr-4": {
      "Source\\": "app/"
    },
    "files": [
      "cli.php"
    ]
  },
  "authors": [
    {
      "name": "RoxCMS TeaM Developers", 
      "email": "roxcmsteam@gmail.com",
      "role": "Developement"
    }
  ],
  "require": {
    "php": "^8.1",
    "cocur/slugify": "^4.1",
    "guzzlehttp/guzzle": "^7.4",
    "league/plates": "3.*",
    "mercadopago/dx-php": "2.5.3",
    "phpmailer/phpmailer": "^6.5",
    "stripe/stripe-php": "^19.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "symfony/var-dumper": "^6.4"
  },
  "config": {
    "platform": {
      "php": "8.1"
    },
    "optimize-autoloader": true,
    "sort-packages": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "composer/package-versions-deprecated": true
    }
  },
  "scripts": {
    "cs-fix": "php-cs-fixer fix ."
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
